# =============================================================================
# Arivu Systems CRM - Environment Configuration Template
# =============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Update the values below with your actual configuration
# 3. NEVER commit .env to git (it's in .gitignore)
#
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Choose ONE: Local MongoDB OR MongoDB Atlas (Cloud)

# Option 1: Local MongoDB (if you have MongoDB installed locally)
MONGO_URI_LOCAL=mongodb://localhost:27017/arivu

# Option 2: MongoDB Atlas (Cloud)
MONGO_URI_ATLAS=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/arivu?retryWrites=true&w=majority

# ACTIVE CONNECTION (uncomment one)
MONGO_URI=mongodb://localhost:27017/arivu
MONGODB_URI=mongodb://localhost:27017/arivu
MASTER_DB_NAME=arivu_master

# -----------------------------------------------------------------------------
# SECURITY (CHANGE THESE IN PRODUCTION!)
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this
REFRESH_TOKEN_EXPIRE=30d
MASTER_API_KEY=your_master_api_key_change_this

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
# Local Development
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000,http://localhost:5174

# Production (Vercel frontend + OCI API example)
# CLIENT_URL=https://www.arivusystems.com
# CORS_ORIGINS=https://www.arivusystems.com,https://arivusystems.com,https://YOUR_API_HOST

# -----------------------------------------------------------------------------
# ADMIN DEFAULTS
# -----------------------------------------------------------------------------
DEFAULT_ADMIN_EMAIL=admin@arivusystems.com
DEFAULT_ADMIN_PASSWORD=Admin@123456

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
ENABLE_HEALTH_CHECKER=false
ENABLE_METRICS_COLLECTOR=false

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Use ONE: Mailtrap (dev) OR AWS SES (production)
#
# --- Development: Mailtrap (catches emails, no real delivery) ---
# Sign up: https://mailtrap.io → Inboxes → SMTP Settings
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=d2af624bb24e95
SMTP_PASS=y949d759e9cc484
TOKEN=bfc58032be6f2585783129e2a8623216
#
# --- Production: AWS SES ---
# Get these from AWS Console: https://console.aws.amazon.com/ses/
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_access_key
#
# --- Common (required for both) ---
EMAIL_FROM=noreply@arivusystems.com
EMAIL_FROM_NAME=Arivu Systems
EMAIL_REPLY_TO=support@arivusystems.com
#
# --- Phase 2: Inbound (Reply-To routing) ---
# Domain for Reply-To plus-addressing (e.g. replies+token@yourdomain.com)
EMAIL_REPLY_TO_DOMAIN=arivusystems.com
# Inbound receiving address (domain used for Reply-To; e.g. replies@yourdomain.com)
EMAIL_INBOUND_ADDRESS=replies@arivusystems.com
# HMAC secret for signing Reply-To tokens (never expose; generate: openssl rand -hex 32)
EMAIL_REPLY_TOKEN_SECRET=
#
# --- Phase 4: SES Event Notifications (delivery/bounce/complaint) ---
# Configure AWS SES to publish to SNS topic, then SNS HTTP subscription to:
#   https://your-domain.com/api/webhooks/email/ses-events

# Redis for email queue (optional but recommended)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# FEATURES
# -----------------------------------------------------------------------------
ENABLE_DEMO_CONVERSION=true
ENABLE_INSTANCE_PROVISIONING=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_STRIPE_INTEGRATION=false

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
DEBUG_PROVISIONING=false
DEBUG_KUBERNETES=false
DEBUG_DATABASE=false
DEBUG_DNS=false

# -----------------------------------------------------------------------------
# OTHER
# -----------------------------------------------------------------------------
BASE_DOMAIN=arivusystems.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
GENERAL_API_RATE_LIMIT_MAX_REQUESTS=300
ORGANIZATION_SETTINGS_RATE_LIMIT_MAX_REQUESTS=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_REDIS_REQUIRED=false
# Auth fails closed to preserve brute-force protection; general/read-heavy API fails open for uptime.
RATE_LIMIT_REDIS_FAILURE_MODE=fail-closed
GENERAL_RATE_LIMIT_REDIS_FAILURE_MODE=fail-open
ROUTE_RATE_LIMIT_REDIS_FAILURE_MODE=fail-open
AUTH_RATE_LIMIT_REDIS_FAILURE_MODE=fail-closed
SENSITIVE_RATE_LIMIT_REDIS_FAILURE_MODE=fail-closed
# Optional override. Default is <APP_NAME or arivu>:<CACHE_ENV/SENTRY_ENVIRONMENT/NODE_ENV>:rate-limit:
# RATE_LIMIT_REDIS_PREFIX=arivu:development:rate-limit:

RESPONSE_CACHE_TTL_SECONDS=45
RESPONSE_CACHE_TTL_JITTER_SECONDS=10
RESPONSE_CACHE_MAX_PAYLOAD_BYTES=131072
RESPONSE_CACHE_REDIS_REQUIRED=false
# Optional override. Default is <APP_NAME or arivu>:<CACHE_ENV/SENTRY_ENVIRONMENT/NODE_ENV>:response-cache:
# RESPONSE_CACHE_REDIS_PREFIX=arivu:development:response-cache:
RESPONSE_CACHE_IGNORED_QUERY_PARAMS=_,_t,t,timestamp,cacheBust,cache_bust,cb,v
RESPONSE_CACHE_LOG_HITS=false

AUTH_PROGRESSIVE_THROTTLE_ENABLED=true
AUTH_THROTTLE_WINDOW_SECONDS=900
AUTH_THROTTLE_DELAY_AFTER_ATTEMPTS=3
AUTH_THROTTLE_BLOCK_AFTER_ATTEMPTS=8
AUTH_THROTTLE_BASE_DELAY_MS=500
AUTH_THROTTLE_MAX_DELAY_MS=2000

# -----------------------------------------------------------------------------
# Gmail personal inbox sync (Phase 5 — optional)
# Prefer Settings → Integrations → Email provider → "Gmail inbox sync (OAuth app)" (stored per tenant).
# Or set these for a global fallback when the tenant has not configured the OAuth app in the UI.
# MAILBOX_OAUTH_SECRET: AES key material for encrypted tokens (falls back to JWT_SECRET).
# -----------------------------------------------------------------------------
# GOOGLE_GMAIL_CLIENT_ID=
# GOOGLE_GMAIL_CLIENT_SECRET=
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:5000/api/mailboxes/inbox-sync/google/callback
# MAILBOX_OAUTH_SECRET=change_me_long_random_for_mailbox_token_encryption

# Background Gmail inbox sync (API process — requires scheduled jobs enabled)
# ENABLE_SCHEDULED_JOBS=false disables all node-cron tasks including digests, escalation, and this sync.
# ENABLE_GMAIL_INBOX_SYNC_SCHEDULER=false turns off only the Gmail poll (manual "Sync now" still works).
# GMAIL_INBOX_SYNC_CRON defaults to */5 * * * * (every 5 minutes, DIGEST_TIMEZONE applies).
# GMAIL_INBOX_SYNC_MIN_INTERVAL_MINUTES skips a mailbox if it synced more recently than this (default 4).
# GMAIL_INBOX_SYNC_SCHEDULER_DEBUG=true logs per-mailbox results.
# ENABLE_SCHEDULED_JOBS=true
# ENABLE_GMAIL_INBOX_SYNC_SCHEDULER=true
# GMAIL_INBOX_SYNC_CRON=*/5 * * * *
# GMAIL_INBOX_SYNC_MIN_INTERVAL_MINUTES=4
# GMAIL_INBOX_SYNC_SCHEDULER_DEBUG=false

# Snooze wake: in-app notification when a thread's snooze window ends (Phase 6)
# ENABLE_SNOOZE_WAKE_NOTIFICATION_SCHEDULER=false — disable the every-minute tick
# SNOOZE_WAKE_MAX_LOOKBACK_HOURS=72 — only notify for snoozedUntil in [now−lookback, now] (avoids ancient rows)
# SNOOZE_WAKE_BATCH_PER_TENANT=120 — max ThreadView rows processed per tenant per tick
# SNOOZE_WAKE_NOTIFICATION_DEBUG=true — extra logs
