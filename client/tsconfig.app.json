{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": [
    "src/**/__tests__/*",
    "src/components/organizations/OrganizationMetricsWidget.vue"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "tsBuildInfoFile": "./.tsbuildinfo/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "vueCompilerOptions": {
    "globalTypesPath": "./.tsbuildinfo/vue-global-types.d.ts"
  }
}