{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.arivusystems.com/api/$1"
    },
    {
      "source": "/portal/(me|org|health|audits|actions)(.*)",
      "destination": "https://api.arivusystems.com/portal/$1$2"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
